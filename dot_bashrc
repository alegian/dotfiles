# .bashrc

# Source global definitions
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

# User specific environment
if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]; then
    PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi
export PATH

# Uncomment the following line if you don't like systemctl's auto-paging feature:
# export SYSTEMD_PAGER=

# User specific aliases and functions
if [ -d ~/.bashrc.d ]; then
    for rc in ~/.bashrc.d/*; do
        if [ -f "$rc" ]; then
            . "$rc"
        fi
    done
fi
unset rc

gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'

export EDITOR=nvim

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

export PATH="$HOME/.yarn/bin:$PATH"

export ANDROID_HOME=$HOME/Android/Sdk
export PATH=$PATH:$ANDROID_HOME/emulator
export PATH=$PATH:$ANDROID_HOME/platform-tools

[ -f "/home/alegian/.ghcup/env" ] && . "/home/alegian/.ghcup/env" # ghcup-env

alias nvimc='cd ~/.config/nvim && nvim .'

alias mono='cd /home/alegian/projects/givelink/mono'
alias thavma='cd /home/alegian/projects/alegian/thavma'
alias ublue='cd /home/alegian/projects/alegian/ublue'
alias dotfiles='cd /home/alegian/.local/share/chezmoi'

alias day='sudo ddcutil setvcp 10 100'
alias night='sudo ddcutil setvcp 10 50'

alias save-flatpaks='flatpak list --app --columns=application > ~/.config/flatpaks.txt'

alias review='opencode run --command review'

launch_apps() {
  for app in \
    Alacritty \
    com.brave.Browser.desktop \
    md.obsidian.Obsidian.desktop \
    com.discordapp.Discord.desktop
  do
    gtk-launch "$app" &
  done
}

java17() {
  export JAVA_HOME=/var/home/alegian/.gradle/jdks/eclipse_adoptium-17-amd64-linux/jdk-17.0.19+10
  export PATH="$JAVA_HOME/bin:$PATH"
}

java21() {
  export JAVA_HOME=/var/home/alegian/.gradle/jdks/eclipse_adoptium-21-amd64-linux/jdk-21.0.11
  export PATH="$JAVA_HOME/bin:$PATH"
}
