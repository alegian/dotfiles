#!/bin/sh

if [ ! -x "$HOME/.bun/bin/bun" ]; then
  curl -fsSL https://bun.sh/install | sed '/# bun/i break' | bash
fi

if [ ! -s "$HOME/.nvm/nvm.sh" ]; then
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | PROFILE=/dev/null bash
  source ~/.bashrc
  nvm install --lts
  nvm use --lts
  source ~/.bashrc
fi

if [ ! -x "$HOME/.ghcup/bin/ghcup" ]; then
  curl --proto '=https' --tlsv1.2 -sSf https://get-ghcup.haskell.org | sh
fi

npm install --global yarn

yarn global add opencode-ai

set -euo pipefail

install_tarball_app() {
  local name="$1" url="$2" dir_name="$3" bin_name="$4" link_name="$5"
  local install_dir="$HOME/.local/opt/$dir_name"

  [ -d "$install_dir" ] && return 0

  local tmp_dir
  tmp_dir="$(mktemp -d)"

  mkdir -p "$HOME/.local/opt" "$HOME/.local/bin"

  echo "Downloading $name..."
  curl -L "$url" -o "$tmp_dir/app.tar.gz"
  tar -xzf "$tmp_dir/app.tar.gz" -C "$tmp_dir"

  local extracted_dir
  extracted_dir="$(find "$tmp_dir" -maxdepth 1 -mindepth 1 -type d | head -n 1)"

  mv "$extracted_dir" "$install_dir"
  ln -sf "$install_dir/bin/$bin_name" "$HOME/.local/bin/$link_name"
  rm -rf "$tmp_dir"

  echo "$name installed"
}

install_tarball_app "IntelliJ IDEA" \
  "https://download.jetbrains.com/idea/idea-2026.1.1.tar.gz" \
  "idea" "idea" "idea"

install_tarball_app "Android Studio" \
  "https://dl.google.com/android/studio/ide-zips/2025.3.4.7/android-studio-panda4-patch1-linux.tar.gz" \
  "android-studio" "studio.sh" "android-studio"
